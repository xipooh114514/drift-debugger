🧪 scripts/tf32_fix_demo.sh

#!/bin/bash

echo "=== Step 1: Baseline (TF32 OFF) ==="
python examples/tf32_ghost.py --mode off > runA.log

echo "=== Step 2: Drift (TF32 ON) ==="
python examples/tf32_ghost.py --mode on > runB.log

echo "=== Step 3: Diff ==="
drift diff runA.json runB.json

echo "=== Step 4: Generate Patch ==="
drift patch runA.json

echo "=== Step 5: Apply Patch ==="
python examples/train_with_patch.py

echo "=== Step 6: Verify ==="
drift diff runA.json patched.json


